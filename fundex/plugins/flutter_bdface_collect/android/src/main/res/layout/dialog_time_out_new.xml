<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="504dp"
    android:id="@+id/relative_dialog_bg"
    android:background="@drawable/bg_round_time_out">

    <ImageView
        android:id="@+id/image_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:src="@mipmap/ic_warning" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/recognition_failed"
        android:textColor="@color/face_liveness_recognition_failed"
        android:textSize="@dimen/home_sort_font"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="18dp"
        android:layout_below="@id/image_icon"/>
    <TextView
        android:id="@+id/text_title2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/recognition_failed_title"
        android:textColor="@color/face_liveness_recognition_failed_title"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:layout_below="@id/text_title"/>

    <RelativeLayout
        android:id="@+id/attention_pic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_title2"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="32dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="32dp"
        android:paddingBottom="24dp"
        android:background="@drawable/bg_round_time_out_pic_bck">

        <LinearLayout
            android:id="@+id/linear_layout1"
            android:layout_width="74dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:src="@mipmap/icon_moderate_lighting" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:text="@string/moderate_lighting"
                android:textColor="@color/face_liveness_recognition_failed"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear_layout2"
            android:layout_width="74dp"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_marginTop="24dp"
            android:layout_marginRight="24dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:src="@mipmap/icon_face_to_screen" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:text="@string/face_to_screen"
                android:textColor="@color/face_liveness_recognition_failed"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear_layout3"
            android:layout_width="74dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/linear_layout1"
            android:layout_marginLeft="24dp"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:src="@mipmap/icon_avoid_obstruction" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:text="@string/avoid_obstruction"
                android:textColor="@color/face_liveness_recognition_failed"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear_layout4"
            android:layout_width="74dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/linear_layout1"
            android:layout_alignParentRight="true"
            android:layout_marginTop="24dp"
            android:layout_marginRight="24dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:src="@mipmap/icon_clear_camera" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:text="@string/clear_camera"
                android:textColor="@color/face_liveness_recognition_failed"
                android:textSize="14sp" />
        </LinearLayout>

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/attention_pic"
        android:layout_marginTop="32dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:layout_marginBottom="24dp">
        <Button
            android:id="@+id/btn_exit"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="@string/to_return"
            android:textColor="@color/face_liveness_recognition_failed"
            android:textSize="16sp"
            android:layout_weight="1"
            android:background="@drawable/bg_round_time_out_return_btn"
            android:layout_marginRight="16dp"/>
        <Button
            android:id="@+id/btn_again"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/collect_button_recollect"
            android:textColor="@color/face_liveness_timeout_dialog_bg_custom"
            android:textSize="16sp"
            android:layout_below="@id/attention_pic"
            android:background="@drawable/bg_round_time_out_recollect_btn"
            android:layout_toRightOf="@id/btn_exit" />
    </LinearLayout>
</RelativeLayout>